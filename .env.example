# Environment Variables Template
# Copy this file to .env.local and update with your actual values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application title displayed in browser tab and meta tags
VITE_APP_TITLE="Professional Profile Platform"

# Application description for SEO and meta tags
VITE_APP_DESCRIPTION="Create and manage your professional profile with ease"

# Application version (automatically set by build process)
# VITE_APP_VERSION="1.0.0"

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Base URL for API endpoints (if using external API)
# Example: https://api.yourapp.com
# VITE_API_BASE_URL="http://localhost:3000"

# API version for versioned endpoints
# VITE_API_VERSION="v1"

# API timeout in milliseconds
# VITE_API_TIMEOUT="10000"

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# OAuth provider configuration (if using OAuth)
# VITE_OAUTH_CLIENT_ID="your-oauth-client-id"
# VITE_OAUTH_REDIRECT_URI="http://localhost:8080/auth/callback"

# JWT token configuration (if using JWT authentication)
# VITE_JWT_SECRET="your-jwt-secret-key"
# VITE_JWT_EXPIRY="24h"

# =============================================================================
# ANALYTICS AND MONITORING
# =============================================================================

# Google Analytics tracking ID
# VITE_GA_TRACKING_ID="G-XXXXXXXXXX"

# Sentry DSN for error tracking
# VITE_SENTRY_DSN="https://xxxxxxxxxx@sentry.io/xxxxxxx"

# Environment name for monitoring (development, staging, production)
# VITE_ENVIRONMENT="development"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features during development
# VITE_FEATURE_DARK_MODE="true"
# VITE_FEATURE_ANALYTICS="false"
# VITE_FEATURE_NOTIFICATIONS="true"

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# File upload service configuration
# VITE_UPLOAD_SERVICE_URL="https://upload.yourapp.com"
# VITE_UPLOAD_MAX_SIZE="5242880"  # 5MB in bytes

# Email service configuration
# VITE_EMAIL_SERVICE_URL="https://email.yourapp.com"

# CDN configuration for static assets
# VITE_CDN_URL="https://cdn.yourapp.com"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug mode (shows additional console logs)
# VITE_DEBUG="true"

# Mock API responses for development
# VITE_MOCK_API="true"

# Development server port (override default 8080)
# VITE_DEV_PORT="3000"

# =============================================================================
# SOCIAL MEDIA INTEGRATION
# =============================================================================

# Social media sharing configuration
# VITE_SOCIAL_FACEBOOK_APP_ID="your-facebook-app-id"
# VITE_SOCIAL_TWITTER_HANDLE="@yourhandle"
# VITE_SOCIAL_LINKEDIN_PAGE="your-company-page"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CSRF token configuration
# VITE_CSRF_TOKEN="your-csrf-token"

# Content Security Policy settings
# VITE_CSP_ENABLED="true"

# Rate limiting configuration
# VITE_RATE_LIMIT_MAX_REQUESTS="100"
# VITE_RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Image optimization settings
# VITE_IMAGE_QUALITY="80"
# VITE_IMAGE_FORMAT="webp"

# Lazy loading configuration
# VITE_LAZY_LOADING="true"

# Cache configuration
# VITE_CACHE_DURATION="3600"  # 1 hour in seconds

# =============================================================================
# NOTES AND GUIDELINES
# =============================================================================

# IMPORTANT SECURITY NOTES:
# 1. Never commit actual environment variables to version control
# 2. All VITE_ prefixed variables are exposed to the client-side code
# 3. Do not store sensitive data (passwords, private keys) in VITE_ variables
# 4. Use server-side environment variables for sensitive configuration

# USAGE EXAMPLES:
# 
# In your React components:
# const apiUrl = import.meta.env.VITE_API_BASE_URL;
# const appTitle = import.meta.env.VITE_APP_TITLE;
# 
# In conditional logic:
# if (import.meta.env.VITE_DEBUG === 'true') {
#   console.log('Debug mode enabled');
# }

# ENVIRONMENT-SPECIFIC FILES:
# - .env.local (local development - highest priority)
# - .env.development (development environment)
# - .env.staging (staging environment)
# - .env.production (production environment)
# - .env (default values - lowest priority)

# For more information on Vite environment variables:
# https://vitejs.dev/guide/env-and-mode.html